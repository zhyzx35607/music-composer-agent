{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.music-agent/schemas/revision_plan_schema.json",
  "title": "Music Revision Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "intent",
    "summary",
    "strength",
    "scope",
    "preserve",
    "operations"
  ],
  "properties": {
    "version": { "const": "1.0" },
    "intent": { "type": "string", "minLength": 1, "maxLength": 80 },
    "summary": { "type": "string", "minLength": 1, "maxLength": 500 },
    "strength": { "type": "number", "minimum": 0, "maximum": 1 },
    "scope": { "$ref": "#/$defs/scope" },
    "preserve": {
      "type": "object",
      "additionalProperties": false,
      "required": ["duration", "time_signature", "instruments", "outside_scope"],
      "properties": {
        "duration": { "type": "boolean" },
        "time_signature": { "type": "boolean" },
        "instruments": { "type": "boolean" },
        "outside_scope": { "type": "boolean" }
      }
    },
    "max_changed_note_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
    "metadata_updates": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "style": { "type": "string" },
        "mood": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "key": { "type": "string" },
        "chord_progression": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    },
    "operations": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "enum": [
              "set_tempo",
              "scale_tempo",
              "transpose",
              "velocity_shift",
              "velocity_scale",
              "duration_scale",
              "note_edits",
              "add_notes",
              "remove_notes",
              "set_program",
              "add_track",
              "remove_track"
            ]
          },
          "start_beat": { "type": "number", "minimum": 0 },
          "end_beat": { "type": "number", "exclusiveMinimum": 0 },
          "track_indices": { "type": "array", "minItems": 1, "items": { "type": "integer", "minimum": 0 } },
          "bpm": { "type": "integer", "minimum": 40, "maximum": 220 },
          "factor": { "type": "number", "minimum": 0.25, "maximum": 4 },
          "semitones": { "type": "integer", "minimum": -24, "maximum": 24 },
          "amount": { "type": "integer", "minimum": -64, "maximum": 64 },
          "track_index": { "type": "integer", "minimum": 0 },
          "note_index": { "type": "integer", "minimum": 0 },
          "program": { "type": "integer", "minimum": 0, "maximum": 127 },
          "instrument": { "type": "string" },
          "edits": { "type": "array", "maxItems": 256, "items": { "$ref": "#/$defs/noteEdit" } },
          "targets": { "type": "array", "items": { "$ref": "#/$defs/noteReference" } },
          "notes": { "type": "array", "maxItems": 256, "items": { "$ref": "#/$defs/note" } },
          "track": { "type": "object" }
        }
      }
    }
  },
  "$defs": {
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_beat", "end_beat", "track_indices"],
      "properties": {
        "start_beat": { "type": "number", "minimum": 0 },
        "end_beat": { "type": "number", "exclusiveMinimum": 0 },
        "track_indices": { "type": "array", "minItems": 1, "items": { "type": "integer", "minimum": 0 } }
      }
    },
    "noteReference": {
      "type": "object",
      "required": ["track_index", "note_index"],
      "properties": {
        "track_index": { "type": "integer", "minimum": 0 },
        "note_index": { "type": "integer", "minimum": 0 }
      }
    },
    "noteEdit": {
      "allOf": [
        { "$ref": "#/$defs/noteReference" },
        {
          "type": "object",
          "properties": {
            "pitch": { "type": "integer", "minimum": 0, "maximum": 127 },
            "start": { "type": "number", "minimum": 0 },
            "duration": { "type": "number", "exclusiveMinimum": 0, "maximum": 32 },
            "velocity": { "type": "integer", "minimum": 1, "maximum": 127 }
          }
        }
      ]
    },
    "note": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pitch", "start", "duration", "velocity"],
      "properties": {
        "pitch": { "type": "integer", "minimum": 0, "maximum": 127 },
        "start": { "type": "number", "minimum": 0 },
        "duration": { "type": "number", "exclusiveMinimum": 0, "maximum": 32 },
        "velocity": { "type": "integer", "minimum": 1, "maximum": 127 }
      }
    }
  }
}

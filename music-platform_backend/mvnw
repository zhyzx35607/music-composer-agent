# ----------------------------------------------------------------------------
# Maven Wrapper startup script
# ----------------------------------------------------------------------------

# OS specific support
cygwin=false
mingw=false
case "`uname`" in
  CYGWIN*) cygwin=true;;
  MINGW*) mingw=true;;
esac

# Resolve links
PRG="$0"
while [ -h "$PRG" ]; do
    ls=`ls -ld "$PRG"`
    link=`expr "$ls" : '.*-> \(.*\)$'`
    if expr "$link" : '/.*' > /dev/null; then
        PRG="$link"
    else
        PRG="`dirname "$PRG"`/$link"
    fi
done

# Set project base directory
PRGDIR=`dirname "$PRG"`
export MAVEN_PROJECTBASEDIR=`cd "$PRGDIR" >/dev/null; pwd`

# Set JAVA_HOME if not set
if [ -z "$JAVA_HOME" ]; then
    JAVA_BIN="`which java 2>/dev/null`"
    if [ -n "$JAVA_BIN" ]; then
        JAVA_HOME=`dirname "$JAVA_BIN"`/..
        export JAVA_HOME
    fi
fi

# Execute Maven Wrapper
WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
if [ ! -f "$WRAPPER_JAR" ]; then
    echo "ERROR: Maven Wrapper JAR not found at $WRAPPER_JAR"
    echo "Please download it from: https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.3.2/maven-wrapper-3.3.2.jar"
    exit 1
fi

exec "$JAVA_HOME/bin/java" \
    $MAVEN_OPTS \
    -classpath "$WRAPPER_JAR" \
    org.apache.maven.wrapper.MavenWrapperMain \
    "$@"

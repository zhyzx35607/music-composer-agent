{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.music-agent/schemas/music_json_schema.json",
  "title": "GPT Music JSON",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "title",
    "description",
    "duration_seconds",
    "tempo_bpm",
    "key",
    "time_signature",
    "ticks_per_beat",
    "total_beats",
    "style",
    "mood",
    "chord_progression",
    "tracks"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "duration_seconds": {
      "type": "number",
      "minimum": 5,
      "maximum": 180
    },
    "tempo_bpm": {
      "type": "integer",
      "minimum": 40,
      "maximum": 220
    },
    "key": {
      "type": "string",
      "minLength": 1,
      "maxLength": 32
    },
    "time_signature": {
      "type": "string",
      "pattern": "^[1-9][0-9]?/(1|2|4|8|16)$"
    },
    "ticks_per_beat": {
      "type": "integer",
      "const": 480
    },
    "total_beats": {
      "type": "number",
      "minimum": 1
    },
    "style": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "mood": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 40
      }
    },
    "chord_progression": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 16
      }
    },
    "tracks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "$ref": "#/$defs/track"
      }
    }
  },
  "$defs": {
    "track": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "role",
        "instrument",
        "channel",
        "program",
        "is_drum",
        "notes"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "role": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "instrument": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "channel": {
          "type": "integer",
          "minimum": 0,
          "maximum": 15
        },
        "program": {
          "type": "integer",
          "minimum": 0,
          "maximum": 127
        },
        "is_drum": {
          "type": "boolean"
        },
        "notes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 512,
          "items": {
            "$ref": "#/$defs/note"
          }
        }
      }
    },
    "note": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pitch",
        "start",
        "duration",
        "velocity"
      ],
      "properties": {
        "pitch": {
          "type": "integer",
          "minimum": 0,
          "maximum": 127
        },
        "start": {
          "type": "number",
          "minimum": 0
        },
        "duration": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 32
        },
        "velocity": {
          "type": "integer",
          "minimum": 1,
          "maximum": 127
        }
      }
    }
  }
}
